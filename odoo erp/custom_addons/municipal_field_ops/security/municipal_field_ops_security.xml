<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_mfo_manager" model="res.groups">
        <field name="name">Хотын талбайн ажил / Менежер</field>
        <field name="implied_ids" eval="[(4, ref('project.group_project_manager')), (4, ref('fleet.fleet_group_user')), (4, ref('hr.group_hr_user'))]"/>
    </record>

    <record id="group_mfo_dispatcher" model="res.groups">
        <field name="name">Хотын талбайн ажил / Диспетчер</field>
        <field name="implied_ids" eval="[(4, ref('project.group_project_user')), (4, ref('fleet.fleet_group_user')), (4, ref('hr.group_hr_user'))]"/>
    </record>

    <record id="group_mfo_inspector" model="res.groups">
        <field name="name">Хотын талбайн ажил / Хянагч</field>
        <field name="implied_ids" eval="[(4, ref('project.group_project_user'))]"/>
    </record>

    <record id="group_mfo_mobile_user" model="res.groups">
        <field name="name">Хотын талбайн ажил / Гар утасны хэрэглэгч</field>
        <field name="implied_ids" eval="[(4, ref('project.group_project_user'))]"/>
    </record>

    <record id="rule_mfo_stop_line_mobile_scope" model="ir.rule">
        <field name="name">MFO stop line mobile scope</field>
        <field name="model_id" ref="model_mfo_stop_execution_line"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
        <field name="domain_force">[('task_id.user_ids', 'in', user.id)]</field>
        <field name="groups" eval="[(4, ref('municipal_field_ops.group_mfo_mobile_user')), (4, ref('municipal_field_ops.group_mfo_inspector'))]"/>
    </record>

    <record id="rule_mfo_proof_image_mobile_scope" model="ir.rule">
        <field name="name">MFO proof image mobile scope</field>
        <field name="model_id" ref="model_mfo_proof_image"/>
        <field name="perm_unlink" eval="False"/>
        <field name="domain_force">[('task_id.user_ids', 'in', user.id)]</field>
        <field name="groups" eval="[(4, ref('municipal_field_ops.group_mfo_mobile_user')), (4, ref('municipal_field_ops.group_mfo_inspector'))]"/>
    </record>

    <record id="rule_mfo_issue_mobile_scope" model="ir.rule">
        <field name="name">MFO issue mobile scope</field>
        <field name="model_id" ref="model_mfo_issue_report"/>
        <field name="perm_unlink" eval="False"/>
        <field name="domain_force">[('task_id.user_ids', 'in', user.id)]</field>
        <field name="groups" eval="[(4, ref('municipal_field_ops.group_mfo_mobile_user')), (4, ref('municipal_field_ops.group_mfo_inspector'))]"/>
    </record>

    <record id="rule_mfo_weight_mobile_scope" model="ir.rule">
        <field name="name">MFO weight mobile scope</field>
        <field name="model_id" ref="model_mfo_weight_measurement"/>
        <field name="perm_unlink" eval="False"/>
        <field name="domain_force">[('task_id.user_ids', 'in', user.id)]</field>
        <field name="groups" eval="[(4, ref('municipal_field_ops.group_mfo_mobile_user')), (4, ref('municipal_field_ops.group_mfo_inspector'))]"/>
    </record>
</odoo>
