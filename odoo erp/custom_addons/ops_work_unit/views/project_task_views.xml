<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_task_form_ops_work_unit" model="ir.ui.view">
        <field name="name">project.task.form.ops.work.unit</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="ops_field_reporting.view_task_form_ops_field_reporting"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='ops_planned_quantity']" position="after">
                <field name="ops_allowed_unit_summary" readonly="1" invisible="not ops_allowed_unit_summary"/>
            </xpath>
            <xpath expr="//field[@name='ops_measurement_unit']" position="replace">
                <field name="ops_measurement_unit_id"
                       placeholder="Хэмжих нэгж сонгоно уу"
                       domain="[('id', 'in', ops_allowed_unit_ids)]"
                       options="{'no_create': True, 'no_open': True}"
                       readonly="not project_id"/>
            </xpath>
            <xpath expr="//field[@name='task_measurement_unit']" position="replace">
                <field name="task_measurement_unit_id" readonly="1" options="{'no_open': True, 'no_create': True}"/>
            </xpath>
        </field>
    </record>

    <record id="quick_create_task_form_ops_work_unit" model="ir.ui.view">
        <field name="name">project.task.form.quick.create.ops.work.unit</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="ops_field_reporting.quick_create_task_form_ops_field_reporting"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='ops_measurement_unit']" position="replace">
                <field name="ops_measurement_unit_id"
                       placeholder="Хэмжих нэгж сонгоно уу"
                       domain="[('id', 'in', ops_allowed_unit_ids)]"
                       options="{'no_create': True, 'no_open': True}"/>
            </xpath>
            <xpath expr="//field[@name='ops_planned_quantity']" position="after">
                <field name="ops_allowed_unit_summary" readonly="1" invisible="not ops_allowed_unit_summary"/>
            </xpath>
        </field>
    </record>
</odoo>
