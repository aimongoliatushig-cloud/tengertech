<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_mpm_project_general_manager" model="ir.rule">
        <field name="name">Ерөнхий менежер бүх төсөл</field>
        <field name="model_id" ref="project.model_project_project"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('municipal_project_mobile.group_general_manager'))]"/>
    </record>

    <record id="rule_mpm_project_project_manager" model="ir.rule">
        <field name="name">Төслийн менежер өөрийн төсөл</field>
        <field name="model_id" ref="project.model_project_project"/>
        <field name="domain_force">[('mpm_project_manager_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('municipal_project_mobile.group_project_manager'))]"/>
    </record>

    <record id="rule_mpm_project_team_leader" model="ir.rule">
        <field name="name">Багийн ахлагч оролцож буй төсөл</field>
        <field name="model_id" ref="project.model_project_project"/>
        <field name="domain_force">['|', ('mpm_team_leader_id', '=', user.id), ('task_ids.mpm_team_leader_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('municipal_project_mobile.group_team_leader'))]"/>
    </record>

    <record id="rule_mpm_project_worker" model="ir.rule">
        <field name="name">Ажилтан оролцож буй төсөл</field>
        <field name="model_id" ref="project.model_project_project"/>
        <field name="domain_force">[('task_ids.mpm_worker_ids', 'in', [user.id])]</field>
        <field name="groups" eval="[(4, ref('municipal_project_mobile.group_worker'))]"/>
    </record>

    <record id="rule_mpm_task_general_manager" model="ir.rule">
        <field name="name">Ерөнхий менежер бүх ажил</field>
        <field name="model_id" ref="project.model_project_task"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('municipal_project_mobile.group_general_manager'))]"/>
    </record>

    <record id="rule_mpm_task_project_manager" model="ir.rule">
        <field name="name">Төслийн менежер өөрийн ажил</field>
        <field name="model_id" ref="project.model_project_task"/>
        <field name="domain_force">[('project_id.mpm_project_manager_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('municipal_project_mobile.group_project_manager'))]"/>
    </record>

    <record id="rule_mpm_task_team_leader" model="ir.rule">
        <field name="name">Багийн ахлагч оноогдсон ажил</field>
        <field name="model_id" ref="project.model_project_task"/>
        <field name="domain_force">[('mpm_team_leader_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('municipal_project_mobile.group_team_leader'))]"/>
    </record>

    <record id="rule_mpm_task_worker" model="ir.rule">
        <field name="name">Ажилтан оноогдсон ажил</field>
        <field name="model_id" ref="project.model_project_task"/>
        <field name="domain_force">[('mpm_worker_ids', 'in', [user.id])]</field>
        <field name="groups" eval="[(4, ref('municipal_project_mobile.group_worker'))]"/>
    </record>

    <record id="rule_mpm_photo_general_manager" model="ir.rule">
        <field name="name">Ерөнхий менежер бүх зураг</field>
        <field name="model_id" ref="model_municipal_project_report_photo"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('municipal_project_mobile.group_general_manager'))]"/>
    </record>

    <record id="rule_mpm_photo_project_manager" model="ir.rule">
        <field name="name">Төслийн менежер өөрийн төслийн зураг</field>
        <field name="model_id" ref="model_municipal_project_report_photo"/>
        <field name="domain_force">[('task_id.project_id.mpm_project_manager_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('municipal_project_mobile.group_project_manager'))]"/>
    </record>

    <record id="rule_mpm_photo_team_leader" model="ir.rule">
        <field name="name">Багийн ахлагч оноогдсон ажлын зураг</field>
        <field name="model_id" ref="model_municipal_project_report_photo"/>
        <field name="domain_force">[('task_id.mpm_team_leader_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('municipal_project_mobile.group_team_leader'))]"/>
    </record>

    <record id="rule_mpm_photo_worker" model="ir.rule">
        <field name="name">Ажилтан өөрийн ажлын зураг</field>
        <field name="model_id" ref="model_municipal_project_report_photo"/>
        <field name="domain_force">[('task_id.mpm_worker_ids', 'in', [user.id])]</field>
        <field name="groups" eval="[(4, ref('municipal_project_mobile.group_worker'))]"/>
    </record>
</odoo>
