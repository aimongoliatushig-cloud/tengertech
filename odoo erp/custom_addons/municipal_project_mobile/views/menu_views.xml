<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_mpm_project_mobile" model="ir.actions.act_window">
        <field name="name">Төслүүд</field>
        <field name="res_model">project.project</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="municipal_project_mobile.view_mpm_project_search"/>
        <field name="context">{}</field>
    </record>

    <record id="action_mpm_project_mobile_kanban" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="municipal_project_mobile.view_mpm_project_kanban"/>
        <field name="act_window_id" ref="municipal_project_mobile.action_mpm_project_mobile"/>
    </record>
    <record id="action_mpm_project_mobile_list" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="municipal_project_mobile.view_mpm_project_list"/>
        <field name="act_window_id" ref="municipal_project_mobile.action_mpm_project_mobile"/>
    </record>
    <record id="action_mpm_project_mobile_form" model="ir.actions.act_window.view">
        <field name="sequence" eval="3"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="municipal_project_mobile.view_mpm_project_form"/>
        <field name="act_window_id" ref="municipal_project_mobile.action_mpm_project_mobile"/>
    </record>

    <record id="action_mpm_task_mobile" model="ir.actions.act_window">
        <field name="name">Ажилууд</field>
        <field name="res_model">project.task</field>
        <field name="view_mode">kanban,list,form,calendar</field>
        <field name="search_view_id" ref="municipal_project_mobile.view_mpm_task_search"/>
        <field name="context">{}</field>
    </record>

    <record id="action_mpm_task_mobile_kanban" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="municipal_project_mobile.view_mpm_task_kanban"/>
        <field name="act_window_id" ref="municipal_project_mobile.action_mpm_task_mobile"/>
    </record>
    <record id="action_mpm_task_mobile_list" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="municipal_project_mobile.view_mpm_task_list"/>
        <field name="act_window_id" ref="municipal_project_mobile.action_mpm_task_mobile"/>
    </record>
    <record id="action_mpm_task_mobile_form" model="ir.actions.act_window.view">
        <field name="sequence" eval="3"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="municipal_project_mobile.view_mpm_task_form"/>
        <field name="act_window_id" ref="municipal_project_mobile.action_mpm_task_mobile"/>
    </record>
    <record id="action_mpm_task_mobile_calendar" model="ir.actions.act_window.view">
        <field name="sequence" eval="4"/>
        <field name="view_mode">calendar</field>
        <field name="view_id" ref="municipal_project_mobile.view_mpm_task_calendar"/>
        <field name="act_window_id" ref="municipal_project_mobile.action_mpm_task_mobile"/>
    </record>

    <record id="action_mpm_today_tasks" model="ir.actions.act_window">
        <field name="name">Өнөөдрийн ажил</field>
        <field name="res_model">project.task</field>
        <field name="view_mode">kanban,list,form,calendar</field>
        <field name="search_view_id" ref="municipal_project_mobile.view_mpm_task_search"/>
        <field name="context">{'search_default_today': 1}</field>
        <field name="domain">[('date_deadline', '=', context_today())]</field>
    </record>
    <record id="action_mpm_today_tasks_kanban" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="municipal_project_mobile.view_mpm_task_kanban"/>
        <field name="act_window_id" ref="municipal_project_mobile.action_mpm_today_tasks"/>
    </record>
    <record id="action_mpm_today_tasks_list" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="municipal_project_mobile.view_mpm_task_list"/>
        <field name="act_window_id" ref="municipal_project_mobile.action_mpm_today_tasks"/>
    </record>
    <record id="action_mpm_today_tasks_form" model="ir.actions.act_window.view">
        <field name="sequence" eval="3"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="municipal_project_mobile.view_mpm_task_form"/>
        <field name="act_window_id" ref="municipal_project_mobile.action_mpm_today_tasks"/>
    </record>
    <record id="action_mpm_today_tasks_calendar" model="ir.actions.act_window.view">
        <field name="sequence" eval="4"/>
        <field name="view_mode">calendar</field>
        <field name="view_id" ref="municipal_project_mobile.view_mpm_task_calendar"/>
        <field name="act_window_id" ref="municipal_project_mobile.action_mpm_today_tasks"/>
    </record>

    <record id="action_mpm_report_review" model="ir.actions.act_window">
        <field name="name">Тайлан</field>
        <field name="res_model">project.task</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="municipal_project_mobile.view_mpm_task_search"/>
        <field name="context">{'search_default_submitted': 1}</field>
        <field name="domain">[('report_status', '=', 'submitted')]</field>
    </record>
    <record id="action_mpm_report_review_kanban" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="municipal_project_mobile.view_mpm_task_kanban"/>
        <field name="act_window_id" ref="municipal_project_mobile.action_mpm_report_review"/>
    </record>
    <record id="action_mpm_report_review_list" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="municipal_project_mobile.view_mpm_task_list"/>
        <field name="act_window_id" ref="municipal_project_mobile.action_mpm_report_review"/>
    </record>
    <record id="action_mpm_report_review_form" model="ir.actions.act_window.view">
        <field name="sequence" eval="3"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="municipal_project_mobile.view_mpm_task_form"/>
        <field name="act_window_id" ref="municipal_project_mobile.action_mpm_report_review"/>
    </record>

    <record id="action_mpm_monthly_schedule" model="ir.actions.act_window">
        <field name="name">Сарын хуваарь</field>
        <field name="res_model">project.task</field>
        <field name="view_mode">calendar,list,kanban,form</field>
        <field name="search_view_id" ref="municipal_project_mobile.view_mpm_task_search"/>
        <field name="context">{}</field>
    </record>
    <record id="action_mpm_monthly_schedule_calendar" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">calendar</field>
        <field name="view_id" ref="municipal_project_mobile.view_mpm_task_calendar"/>
        <field name="act_window_id" ref="municipal_project_mobile.action_mpm_monthly_schedule"/>
    </record>
    <record id="action_mpm_monthly_schedule_list" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="municipal_project_mobile.view_mpm_task_list"/>
        <field name="act_window_id" ref="municipal_project_mobile.action_mpm_monthly_schedule"/>
    </record>
    <record id="action_mpm_monthly_schedule_kanban" model="ir.actions.act_window.view">
        <field name="sequence" eval="3"/>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="municipal_project_mobile.view_mpm_task_kanban"/>
        <field name="act_window_id" ref="municipal_project_mobile.action_mpm_monthly_schedule"/>
    </record>
    <record id="action_mpm_monthly_schedule_form" model="ir.actions.act_window.view">
        <field name="sequence" eval="4"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="municipal_project_mobile.view_mpm_task_form"/>
        <field name="act_window_id" ref="municipal_project_mobile.action_mpm_monthly_schedule"/>
    </record>

    <record id="action_mpm_open_dashboard_server" model="ir.actions.server">
        <field name="name">Хяналтын самбар</field>
        <field name="model_id" ref="model_municipal_project_dashboard"/>
        <field name="state">code</field>
        <field name="code">action = env['municipal.project.dashboard'].action_open_dashboard()</field>
    </record>

    <menuitem id="menu_mpm_root"
              name="Талбайн төслийн удирдлага"
              sequence="40"
              groups="municipal_project_mobile.group_general_manager,municipal_project_mobile.group_project_manager,municipal_project_mobile.group_team_leader,municipal_project_mobile.group_worker"/>

    <menuitem id="menu_mpm_dashboard"
              name="Хяналтын самбар"
              parent="municipal_project_mobile.menu_mpm_root"
              action="municipal_project_mobile.action_mpm_open_dashboard_server"
              sequence="1"
              groups="municipal_project_mobile.group_general_manager,municipal_project_mobile.group_project_manager,municipal_project_mobile.group_team_leader,municipal_project_mobile.group_worker"/>

    <menuitem id="menu_mpm_projects"
              name="Төслүүд"
              parent="municipal_project_mobile.menu_mpm_root"
              action="municipal_project_mobile.action_mpm_project_mobile"
              sequence="2"
              groups="municipal_project_mobile.group_general_manager,municipal_project_mobile.group_project_manager,municipal_project_mobile.group_team_leader"/>

    <menuitem id="menu_mpm_today_tasks"
              name="Өнөөдрийн ажил"
              parent="municipal_project_mobile.menu_mpm_root"
              action="municipal_project_mobile.action_mpm_today_tasks"
              sequence="3"
              groups="municipal_project_mobile.group_general_manager,municipal_project_mobile.group_project_manager,municipal_project_mobile.group_team_leader,municipal_project_mobile.group_worker"/>

    <menuitem id="menu_mpm_report_review"
              name="Тайлан"
              parent="municipal_project_mobile.menu_mpm_root"
              action="municipal_project_mobile.action_mpm_report_review"
              sequence="4"
              groups="municipal_project_mobile.group_general_manager,municipal_project_mobile.group_project_manager"/>

    <menuitem id="menu_mpm_monthly_schedule"
              name="Сарын хуваарь"
              parent="municipal_project_mobile.menu_mpm_root"
              action="municipal_project_mobile.action_mpm_monthly_schedule"
              sequence="5"
              groups="municipal_project_mobile.group_team_leader,municipal_project_mobile.group_worker"/>
</odoo>
