<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mpm_task_search" model="ir.ui.view">
        <field name="name">project.task.search.mpm</field>
        <field name="model">project.task</field>
        <field name="arch" type="xml">
            <search string="Ажил хайх">
                <field name="name" string="Ажил"/>
                <field name="project_id" string="Төсөл"/>
                <field name="mpm_team_leader_id"/>
                <field name="mpm_worker_ids"/>
                <field name="date_deadline" string="Эцсийн хугацаа"/>
                <field name="mpm_execution_state"/>
                <field name="report_status"/>
                <filter string="Өнөөдөр" name="today" domain="[('date_deadline', '=', context_today())]"/>
                <filter string="Шалгалт хүлээж буй" name="submitted" domain="[('report_status', '=', 'submitted')]"/>
                <filter string="Саатсан" name="blocked" domain="[('mpm_execution_state', '=', 'blocked')]"/>
                <filter string="Хоцролттой" name="delayed" domain="[('date_deadline', '&lt;', context_today()), ('mpm_execution_state', '!=', 'done')]"/>
                <filter string="Буцаасан тайлан" name="rejected" domain="[('report_status', '=', 'rejected')]"/>
                <group>
                    <filter string="Төсөл" name="group_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Багийн ахлагч" name="group_team_leader" context="{'group_by': 'mpm_team_leader_id'}"/>
                    <filter string="Ажлын төлөв" name="group_execution" context="{'group_by': 'mpm_execution_state'}"/>
                    <filter string="Тайлангийн төлөв" name="group_report" context="{'group_by': 'report_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_mpm_task_list" model="ir.ui.view">
        <field name="name">project.task.list.mpm</field>
        <field name="model">project.task</field>
        <field name="arch" type="xml">
            <list default_order="date_deadline asc, priority desc"
                  decoration-danger="mpm_execution_state == 'blocked' or mpm_is_delayed"
                  decoration-warning="report_status == 'rejected'">
                <field name="mpm_is_delayed" column_invisible="True"/>
                <field name="name" string="Ажил"/>
                <field name="project_id" string="Төсөл"/>
                <field name="date_deadline" string="Эцсийн хугацаа"/>
                <field name="mpm_execution_state" string="Ажлын төлөв" widget="badge"/>
                <field name="report_status" string="Тайлангийн төлөв" widget="badge"/>
                <field name="progress_percent" string="Гүйцэтгэл" widget="progressbar"/>
                <field name="mpm_photo_count" string="Зураг" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_mpm_task_kanban" model="ir.ui.view">
        <field name="name">project.task.kanban.mpm</field>
        <field name="model">project.task</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="project_id"/>
                <field name="date_deadline"/>
                <field name="mpm_execution_state"/>
                <field name="report_status"/>
                <field name="progress_percent"/>
                <field name="issue_note"/>
                <field name="mpm_photo_count"/>
                <field name="mpm_is_delayed"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click mpm_card mpm_task_card">
                            <div class="mpm_card_header">
                                <strong class="mpm_card_title"><field name="name"/></strong>
                                <span t-if="record.mpm_is_delayed.raw_value" class="mpm_chip mpm_chip_danger">Хоцорсон</span>
                            </div>
                            <div class="mpm_card_body">
                                <div class="mpm_card_badges">
                                    <field name="mpm_execution_state" widget="badge"/>
                                    <field name="report_status" widget="badge"/>
                                </div>
                                <div class="mpm_card_line">
                                    <span>Төсөл</span>
                                    <strong><field name="project_id"/></strong>
                                </div>
                                <div class="mpm_card_line">
                                    <span>Эцсийн хугацаа</span>
                                    <strong><field name="date_deadline"/></strong>
                                </div>
                                <div class="mpm_card_metrics">
                                    <span>Гүйцэтгэл: <field name="progress_percent"/>%</span>
                                    <span>Зураг: <field name="mpm_photo_count"/></span>
                                </div>
                                <div class="progress mpm_progress">
                                    <div class="progress-bar" role="progressbar" t-att-style="'width:%s%%' % (record.progress_percent.raw_value or 0)"/>
                                </div>
                                <small t-if="record.issue_note.raw_value" class="mpm_inline_note">
                                    <field name="issue_note"/>
                                </small>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_mpm_task_calendar" model="ir.ui.view">
        <field name="name">project.task.calendar.mpm</field>
        <field name="model">project.task</field>
        <field name="arch" type="xml">
            <calendar string="Сарын хуваарь" date_start="date_deadline" color="project_id" quick_create="false">
                <field name="name" string="Ажил"/>
                <field name="project_id" string="Төсөл"/>
                <field name="mpm_execution_state" string="Ажлын төлөв"/>
                <field name="report_status" string="Тайлангийн төлөв"/>
            </calendar>
        </field>
    </record>

    <record id="view_mpm_task_form" model="ir.ui.view">
        <field name="name">project.task.form.mpm</field>
        <field name="model">project.task</field>
        <field name="arch" type="xml">
            <form string="Ажил">
                <header>
                    <field name="mpm_execution_state" widget="statusbar" statusbar_visible="planned,in_progress,blocked,done"/>
                    <field name="report_status" widget="statusbar" statusbar_visible="draft,submitted,approved,rejected"/>
                </header>
                <sheet class="mpm_form_sheet">
                    <div class="mpm_section_card">
                        <div class="mpm_section_head">
                            <div>
                                <h2>Ажлын товч</h2>
                                <p>Хамгийн түрүүнд харах үндсэн мэдээлэл.</p>
                            </div>
                        </div>
                        <group>
                            <group>
                                <field name="name" string="Ажлын нэр" placeholder="Ажлын нэр"/>
                                <field name="project_id" string="Төсөл"/>
                                <field name="date_deadline" string="Эцсийн хугацаа"/>
                            </group>
                            <group>
                                <field name="progress_percent" string="Гүйцэтгэл" widget="progressbar"/>
                                <field name="mpm_team_leader_id" string="Багийн ахлагч"/>
                                <field name="mpm_project_manager_id" readonly="1" groups="municipal_project_mobile.group_general_manager,municipal_project_mobile.group_project_manager"/>
                            </group>
                        </group>
                    </div>

                    <div class="mpm_section_card">
                        <div class="mpm_section_head">
                            <div>
                                <h2>Хариуцсан баг</h2>
                                <p>Тухайн ажлыг хэн гүйцэтгэж байгааг харуулна.</p>
                            </div>
                        </div>
                        <group>
                            <group>
                                <field name="mpm_worker_ids" widget="many2many_tags" string="Ажилтнууд"/>
                            </group>
                            <group groups="municipal_project_mobile.group_general_manager,municipal_project_mobile.group_project_manager">
                                <field name="priority" string="Эрэмбэ"/>
                                <field name="tag_ids" string="Шошго" widget="many2many_tags"/>
                            </group>
                        </group>
                    </div>

                    <div class="mpm_section_card">
                        <div class="mpm_section_head">
                            <div>
                                <h2>Зураг нэмэх</h2>
                                <p>Эхлээд ажлын зургаа нэмбэл тайлан илүү хурдан шалгагдана.</p>
                            </div>
                        </div>
                        <field name="report_photo_ids" nolabel="1" mode="kanban,form">
                            <kanban class="o_kanban_mobile">
                                <field name="name"/>
                                <field name="image_1920"/>
                                <field name="note"/>
                                <field name="capture_datetime"/>
                                <templates>
                                    <t t-name="card">
                                        <div class="mpm_photo_card">
                                            <div class="mpm_photo_thumb">
                                                <field name="image_1920" widget="image"/>
                                            </div>
                                            <div class="mpm_photo_meta">
                                                <strong><field name="name"/></strong>
                                                <small t-if="record.note.raw_value"><field name="note"/></small>
                                                <span><field name="capture_datetime"/></span>
                                            </div>
                                        </div>
                                    </t>
                                </templates>
                            </kanban>
                            <form string="Зураг">
                                <sheet>
                                    <group>
                                        <group>
                                            <field name="image_1920" widget="image" class="oe_avatar"/>
                                        </group>
                                        <group>
                                            <field name="name" string="Зургийн нэр"/>
                                            <field name="capture_datetime" string="Оруулсан цаг"/>
                                            <field name="uploaded_by_id" readonly="1" string="Оруулсан хүн"/>
                                            <field name="note" string="Тайлбар"/>
                                        </group>
                                    </group>
                                </sheet>
                            </form>
                        </field>
                    </div>

                    <div class="mpm_section_card">
                        <div class="mpm_section_head">
                            <div>
                                <h2>Тайлан оруулах</h2>
                                <p>Хийсэн ажил, үр дүн, дараагийн алхмаа 2-3 өгүүлбэрээр товч бичнэ үү.</p>
                            </div>
                        </div>
                        <field name="report_note" nolabel="1" placeholder="Өнөөдөр хийсэн ажил, үр дүн, дараагийн алхмыг товч бичнэ үү..."/>
                    </div>

                    <div class="mpm_section_card">
                        <div class="mpm_section_head">
                            <div>
                                <h2>Саад, тайлбар</h2>
                                <p>Саад, эрсдэл, тусламж шаардлагатай зүйлийг энд товч тэмдэглэнэ.</p>
                            </div>
                        </div>
                        <field name="issue_note" nolabel="1" placeholder="Саад, эрсдэл, тусламж шаардлагатай зүйлээ товч бичнэ үү..."/>
                    </div>

                    <div class="mpm_section_card" groups="municipal_project_mobile.group_general_manager,municipal_project_mobile.group_project_manager">
                        <div class="mpm_section_head">
                            <div>
                                <h2>Шийдвэрийн мөр</h2>
                                <p>Шалгалт, баталгаажуулалтын мэдээлэл.</p>
                            </div>
                        </div>
                        <group>
                            <group>
                                <field name="mpm_report_submitted_at" readonly="1" string="Илгээсэн цаг"/>
                                <field name="approved_by_pm" readonly="1" string="Төслийн менежер"/>
                            </group>
                            <group>
                                <field name="mpm_report_reviewed_at" readonly="1" string="Шалгасан цаг"/>
                                <field name="approved_by_gm" readonly="1" string="Ерөнхий менежер"/>
                            </group>
                        </group>
                    </div>

                    <div class="mpm_sticky_action_bar">
                        <button name="action_mpm_start_work" type="object" string="Ажил эхлүүлэх" class="btn btn-primary mpm_action_primary" invisible="not mpm_can_start"/>
                        <button name="action_mpm_mark_done" type="object" string="Дууссан болгох" class="btn btn-success" invisible="not mpm_can_mark_done"/>
                        <button name="action_mpm_mark_blocked" type="object" string="Саатсан болгох" class="btn btn-warning" invisible="not mpm_can_block"/>
                        <button name="action_mpm_submit_report" type="object" string="Тайлан илгээх" class="btn btn-primary mpm_action_primary" invisible="not mpm_can_submit_report"/>
                        <button name="action_mpm_pm_approve_report" type="object" string="Тайлан батлах" class="btn btn-success" invisible="not mpm_can_pm_approve"/>
                        <button name="action_mpm_pm_reject_report" type="object" string="Тайлан буцаах" class="btn btn-secondary" invisible="not mpm_can_pm_reject"/>
                        <button name="action_mpm_gm_override_approve" type="object" string="Нийт баталгаа" class="btn btn-success" invisible="not mpm_can_gm_override"/>
                        <button name="action_mpm_gm_override_reject" type="object" string="Нийт буцаалт" class="btn btn-secondary" invisible="not mpm_can_gm_override"/>
                    </div>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
