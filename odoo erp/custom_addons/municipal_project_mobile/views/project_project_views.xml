<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mpm_project_search" model="ir.ui.view">
        <field name="name">project.project.search.mpm</field>
        <field name="model">project.project</field>
        <field name="arch" type="xml">
            <search string="Төсөл хайх">
                <field name="name" string="Нэр"/>
                <field name="mpm_project_manager_id"/>
                <field name="mpm_team_leader_id"/>
                <field name="mpm_approval_state"/>
                <filter string="Миний төсөл" name="my_projects" domain="[('mpm_project_manager_id', '=', uid)]"/>
                <filter string="Батлаагүй" name="draft_projects" domain="[('mpm_approval_state', '=', 'draft')]"/>
                <filter string="Хоцролттой" name="late_projects" domain="[('task_ids.date_deadline', '&lt;', context_today()), ('task_ids.mpm_execution_state', '!=', 'done')]"/>
                <group>
                    <filter string="Төслийн менежер" name="group_project_manager" context="{'group_by': 'mpm_project_manager_id'}"/>
                    <filter string="Багийн ахлагч" name="group_team_leader" context="{'group_by': 'mpm_team_leader_id'}"/>
                    <filter string="Баталгаажуулалт" name="group_approval_state" context="{'group_by': 'mpm_approval_state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_mpm_project_list" model="ir.ui.view">
        <field name="name">project.project.list.mpm</field>
        <field name="model">project.project</field>
        <field name="arch" type="xml">
            <list default_order="create_date desc">
                <field name="name" string="Төсөл"/>
                <field name="mpm_approval_state" string="Баталгаажуулалт" widget="badge"/>
                <field name="mpm_project_manager_id" string="Төслийн менежер"/>
                <field name="mpm_team_leader_id" string="Багийн ахлагч"/>
                <field name="date_start" string="Эхлэх огноо"/>
                <field name="date" string="Дуусах огноо"/>
                <field name="mpm_pending_report_count" string="Шалгах тайлан"/>
                <field name="mpm_delayed_task_count" string="Хоцролттой ажил"/>
                <field name="mpm_progress_percent" string="Нийт явц" widget="progressbar"/>
            </list>
        </field>
    </record>

    <record id="view_mpm_project_kanban" model="ir.ui.view">
        <field name="name">project.project.kanban.mpm</field>
        <field name="model">project.project</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="mpm_approval_state"/>
                <field name="mpm_project_manager_id"/>
                <field name="mpm_team_leader_id"/>
                <field name="mpm_delayed_task_count"/>
                <field name="mpm_pending_report_count"/>
                <field name="mpm_progress_percent"/>
                <field name="mpm_summary_note"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click mpm_card mpm_project_card">
                            <div class="mpm_card_header">
                                <strong class="mpm_card_title"><field name="name"/></strong>
                                <field name="mpm_approval_state" widget="badge"/>
                            </div>
                            <div class="mpm_card_body">
                                <div class="mpm_card_line">
                                    <span>Төслийн менежер</span>
                                    <strong><field name="mpm_project_manager_id"/></strong>
                                </div>
                                <div class="mpm_card_line">
                                    <span>Багийн ахлагч</span>
                                    <strong><field name="mpm_team_leader_id"/></strong>
                                </div>
                                <div class="mpm_card_metrics">
                                    <span>Шалгах тайлан: <field name="mpm_pending_report_count"/></span>
                                    <span>Хоцролттой: <field name="mpm_delayed_task_count"/></span>
                                </div>
                                <div class="progress mpm_progress">
                                    <div class="progress-bar" role="progressbar" t-att-style="'width:%s%%' % (record.mpm_progress_percent.raw_value or 0)"/>
                                </div>
                                <small class="mpm_inline_note"><field name="mpm_summary_note"/></small>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_mpm_project_form" model="ir.ui.view">
        <field name="name">project.project.form.mpm</field>
        <field name="model">project.project</field>
        <field name="arch" type="xml">
            <form string="Төсөл">
                <header>
                    <field name="mpm_approval_state" widget="statusbar" statusbar_visible="draft,approved"/>
                </header>
                <sheet class="mpm_form_sheet">
                    <div class="mpm_section_card">
                        <div class="mpm_section_head">
                            <div>
                                <h2>Төслийн товч</h2>
                                <p>Төслийн хариуцлага, хугацаа, явцыг хурдан харна.</p>
                            </div>
                        </div>
                        <group>
                            <group>
                                <field name="name" string="Төслийн нэр" placeholder="Төслийн нэр"/>
                                <field name="mpm_general_manager_id" groups="municipal_project_mobile.group_general_manager" string="Ерөнхий менежер"/>
                                <field name="mpm_project_manager_id" string="Төслийн менежер"/>
                                <field name="mpm_team_leader_id" string="Багийн ахлагч"/>
                            </group>
                            <group>
                                <field name="date_start" string="Эхлэх огноо"/>
                                <field name="date" string="Дуусах огноо"/>
                                <field name="mpm_progress_percent" string="Нийт явц" widget="progressbar" readonly="1"/>
                                <field name="mpm_summary_note" readonly="1" string="Товч байдал"/>
                            </group>
                        </group>
                    </div>

                    <div class="mpm_section_card">
                        <div class="mpm_section_head">
                            <div>
                                <h2>Төслийн хяналт</h2>
                                <p>Анхаарах хэмжүүрийг нэг мөрөөр харуулна.</p>
                            </div>
                        </div>
                        <div class="mpm_metric_grid mpm_metric_grid_compact">
                            <div class="mpm_data_card">
                                <span class="mpm_data_label">Нийт ажил</span>
                                <field name="mpm_task_count" nolabel="1" readonly="1"/>
                            </div>
                            <div class="mpm_data_card">
                                <span class="mpm_data_label">Хоцролттой ажил</span>
                                <field name="mpm_delayed_task_count" nolabel="1" readonly="1"/>
                            </div>
                            <div class="mpm_data_card">
                                <span class="mpm_data_label">Шалгах тайлан</span>
                                <field name="mpm_pending_report_count" nolabel="1" readonly="1"/>
                            </div>
                        </div>
                    </div>

                    <div class="mpm_section_card">
                        <div class="mpm_section_head">
                            <div>
                                <h2>Төслийн тайлбар</h2>
                                <p>Зорилго, хүрээ, гол анхаарах зүйлийг товч бичнэ.</p>
                            </div>
                        </div>
                        <field name="description" nolabel="1" placeholder="Төслийн зорилго, хүрээ, гүйцэтгэлийн гол зүйлсийг товч бичнэ үү..."/>
                    </div>

                    <div class="mpm_sticky_action_bar">
                        <button name="action_mpm_open_project_tasks" type="object" string="Ажил харах" class="btn btn-outline-primary"/>
                        <button name="action_mpm_return_to_draft" type="object" string="Дахин нээх" class="btn btn-secondary" invisible="not mpm_can_return_to_draft"/>
                        <button name="action_mpm_approve_project" type="object" string="Төсөл батлах" class="btn btn-primary mpm_action_primary" invisible="not mpm_can_approve"/>
                    </div>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
