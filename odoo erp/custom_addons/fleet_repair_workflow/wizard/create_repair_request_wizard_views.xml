<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_create_repair_request_wizard_form" model="ir.ui.view">
        <field name="name">create.repair.request.wizard.form</field>
        <field name="model">create.repair.request.wizard</field>
        <field name="arch" type="xml">
            <form string="Шинэ засварын хүсэлт">
                <group>
                    <group>
                        <field name="vehicle_id"/>
                        <field name="project_id"/>
                        <field name="maintenance_category"/>
                        <field name="team_leader_id"/>
                    </group>
                    <group>
                        <field name="issue_summary"/>
                        <field name="estimated_repair_hours"/>
                        <field name="create_task"/>
                    </group>
                </group>
                <group>
                    <field name="problem_description"/>
                </group>
                <footer>
                    <button name="action_create_request" type="object" string="Үүсгэх" class="btn btn-primary"/>
                    <button string="Болих" special="cancel" class="btn btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_create_repair_request_wizard" model="ir.actions.act_window">
        <field name="name">Шинэ хүсэлт</field>
        <field name="res_model">create.repair.request.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_create_repair_request_wizard_form"/>
        <field name="target">new</field>
    </record>
</odoo>
