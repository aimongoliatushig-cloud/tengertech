<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fleet_repair_request_reject_wizard_form" model="ir.ui.view">
        <field name="name">fleet.repair.request.reject.wizard.form</field>
        <field name="model">fleet.repair.request.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Татгалзсан шалтгаан">
                <group>
                    <field name="request_id" readonly="1"/>
                    <field name="rejection_reason"/>
                </group>
                <footer>
                    <button name="action_apply_rejection" type="object" string="Татгалзах" class="btn btn-danger"/>
                    <button string="Болих" special="cancel" class="btn btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
