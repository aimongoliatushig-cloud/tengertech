        <field name="name">Захирал</field>
        <field name="implied_ids" eval="[(6, 0, [ref('fleet.fleet_group_user')])]"/>
    </record>

    <record id="group_fleet_repair_manager" model="res.groups">
        <field name="name">Засварын workflow менежер</field>
        <field name="implied_ids" eval="[(6, 0, [
            ref('fleet.fleet_group_user'),
            ref('project.group_project_user'),
            ref('purchase.group_purchase_user'),
            ref('fleet_repair_workflow.group_fleet_repair_mechanic'),
            ref('fleet_repair_workflow.group_fleet_repair_team_leader'),
            ref('fleet_repair_workflow.group_fleet_repair_accounting'),
            ref('fleet_repair_workflow.group_fleet_repair_administration'),
            ref('fleet_repair_workflow.group_fleet_repair_finance'),
            ref('fleet_repair_workflow.group_fleet_repair_purchaser'),
            ref('fleet_repair_workflow.group_fleet_repair_general_manager'),
            ref('fleet_repair_workflow.group_fleet_repair_ceo')
        ])]"/>
    </record>
</odoo>
