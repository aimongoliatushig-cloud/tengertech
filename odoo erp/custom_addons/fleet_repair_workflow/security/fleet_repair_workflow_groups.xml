    </record>

    <record id="group_fleet_repair_administration" model="res.groups">
        <field name="name">Засварын захиргаа</field>
        <field name="implied_ids" eval="[(6, 0, [ref('fleet.fleet_group_user'), ref('purchase.group_purchase_user')])]"/>
    </record>

