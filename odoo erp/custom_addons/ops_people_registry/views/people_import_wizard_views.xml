<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ops_people_import_wizard_form" model="ir.ui.view">
        <field name="name">ops.people.import.wizard.form</field>
        <field name="model">ops.people.import.wizard</field>
        <field name="arch" type="xml">
            <form string="CSV импорт хийх">
                <group>
                    <field name="data_file" filename="filename"/>
                    <field name="filename" invisible="1"/>
                </group>
                <group>
                    <field name="create_missing_departments"/>
                    <field name="create_missing_jobs"/>
                    <field name="create_missing_users"/>
                    <field name="generate_missing_codes"/>
                </group>
                <footer>
                    <button name="action_import" type="object" string="Импорт хийх" class="btn-primary"/>
                    <button string="Болих" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_ops_people_import_wizard" model="ir.actions.act_window">
        <field name="name">CSV импорт хийх</field>
        <field name="res_model">ops.people.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
