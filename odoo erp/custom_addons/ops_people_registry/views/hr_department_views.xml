<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_department_form_ops_registry" model="ir.ui.view">
        <field name="name">hr.department.form.ops.registry</field>
        <field name="model">hr.department</field>
        <field name="inherit_id" ref="hr.view_department_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@colspan='7']/field[@name='parent_id']" position="after">
                <field name="ops_registry_code" groups="ops_people_registry.group_ops_people_admin,ops_people_registry.group_ops_people_hr_manager"/>
                <field name="ops_is_registry_standard" readonly="1" groups="ops_people_registry.group_ops_people_admin,ops_people_registry.group_ops_people_hr_manager"/>
            </xpath>
        </field>
    </record>

    <record id="view_department_tree_ops_registry" model="ir.ui.view">
        <field name="name">hr.department.tree.ops.registry</field>
        <field name="model">hr.department</field>
        <field name="inherit_id" ref="hr.view_department_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list/field[@name='name']" position="after">
                <field name="ops_registry_code" optional="hide"/>
            </xpath>
        </field>
    </record>
</odoo>
