<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_ops_registry" model="ir.ui.view">
        <field name="name">res.users.form.ops.registry</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="ops_project_defaults.view_users_form_ops_project_department"/>
        <field name="arch" type="xml">
            <xpath expr="//h5[@name='h5_phone']/field[@name='phone']" position="replace">
                <field name="work_phone" placeholder="Утас" class="w-75"/>
            </xpath>
            <xpath expr="//page[@name='access_rights']//field[@name='ops_user_type']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_users_tree_ops_registry" model="ir.ui.view">
        <field name="name">res.users.tree.ops.registry</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="ops_project_defaults.view_users_tree_ops_project_department"/>
        <field name="arch" type="xml">
            <xpath expr="//list/field[@name='ops_user_type']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//list/field[@name='role']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>
            <xpath expr="//list/field[@name='login']" position="after">
                <field name="work_phone" string="Утас" optional="show"/>
                <field name="active" optional="show"/>
            </xpath>
        </field>
    </record>

    <record id="view_users_search_ops_registry" model="ir.ui.view">
        <field name="name">res.users.search.ops.registry</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="ops_project_defaults.view_users_search_ops_department"/>
        <field name="arch" type="xml">
            <xpath expr="//search/filter[@name='Inactive']" position="after">
                <separator/>
                <filter name="group_ops_department" string="Алба нэгжээр" domain="[]" context="{'group_by': 'ops_department_id'}"/>
            </xpath>
        </field>
    </record>
</odoo>
