<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ops_people_audit_run_list" model="ir.ui.view">
        <field name="name">ops.people.audit.run.list</field>
        <field name="model">ops.people.audit.run</field>
        <field name="arch" type="xml">
            <list string="Ажилтан бүртгэлийн аудит">
                <field name="name"/>
                <field name="source_label"/>
                <field name="state"/>
                <field name="total_rows"/>
                <field name="updated_users"/>
                <field name="created_employees"/>
                <field name="unresolved_count"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <record id="view_ops_people_audit_line_list" model="ir.ui.view">
        <field name="name">ops.people.audit.line.list</field>
        <field name="model">ops.people.audit.line</field>
        <field name="arch" type="xml">
            <list string="Аудитын мөрүүд">
                <field name="severity"/>
                <field name="issue_type"/>
                <field name="person_name"/>
                <field name="login"/>
                <field name="raw_value"/>
                <field name="normalized_value"/>
                <field name="note"/>
            </list>
        </field>
    </record>

    <record id="view_ops_people_audit_run_form" model="ir.ui.view">
        <field name="name">ops.people.audit.run.form</field>
        <field name="model">ops.people.audit.run</field>
        <field name="arch" type="xml">
            <form string="Ажилтан бүртгэлийн аудит">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="source_label"/>
                            <field name="state"/>
                            <field name="executed_by"/>
                        </group>
                        <group>
                            <field name="total_rows"/>
                            <field name="updated_users"/>
                            <field name="created_employees"/>
                            <field name="linked_employees"/>
                            <field name="created_departments"/>
                            <field name="created_jobs"/>
                            <field name="unresolved_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Аудитын мөрүүд">
                            <field name="line_ids" mode="list">
                                <list create="false" delete="false">
                                    <field name="severity"/>
                                    <field name="issue_type"/>
                                    <field name="person_name"/>
                                    <field name="login"/>
                                    <field name="raw_value"/>
                                    <field name="normalized_value"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>
                        <page string="JSON хураангуй">
                            <field name="summary_json" nolabel="1" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ops_people_audit_run" model="ir.actions.act_window">
        <field name="name">Ажилтан бүртгэлийн аудит</field>
        <field name="res_model">ops.people.audit.run</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
