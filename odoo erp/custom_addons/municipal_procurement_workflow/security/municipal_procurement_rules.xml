        <field name="name">MPW request requester visibility</field>
        <field name="model_id" ref="model_mpw_procurement_request"/>
        <field name="domain_force">['|', '|', '|', ('requester_user_id', '=', user.id), ('project_id.user_id', '=', user.id), ('task_id.user_ids', 'in', user.id), ('department_id.manager_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('municipal_procurement_workflow.group_mpw_requester'))]"/>
    </record>

