<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_mpw_requester" model="res.groups">
        <field name="name">Хэлтсийн дарга / Хүсэлт гаргагч</field>
        <field name="category_id" ref="base.module_category_project_management"/>
        <field name="implied_ids" eval="[(4, ref('project.group_project_user'))]"/>
    </record>

    <record id="group_mpw_storekeeper" model="res.groups">
        <field name="name">Нярав</field>
        <field name="category_id" ref="base.module_category_project_management"/>
        <field name="implied_ids" eval="[(4, ref('project.group_project_user')), (4, ref('purchase.group_purchase_user'))]"/>
    </record>

    <record id="group_mpw_finance" model="res.groups">
        <field name="name">Санхүү</field>
        <field name="category_id" ref="base.module_category_project_management"/>
        <field name="implied_ids" eval="[(4, ref('purchase.group_purchase_user'))]"/>
    </record>

    <record id="group_mpw_office_clerk" model="res.groups">
        <field name="name">Бичиг хэрэг</field>
        <field name="category_id" ref="base.module_category_project_management"/>
        <field name="implied_ids" eval="[(4, ref('project.group_project_user'))]"/>
    </record>

    <record id="group_mpw_contract_officer" model="res.groups">
        <field name="name">Гэрээний ажилтан</field>
        <field name="category_id" ref="base.module_category_project_management"/>
        <field name="implied_ids" eval="[(4, ref('purchase.group_purchase_user'))]"/>
    </record>

    <record id="group_mpw_director" model="res.groups">
        <field name="name">Захирал</field>
        <field name="category_id" ref="base.module_category_project_management"/>
    </record>

    <record id="group_mpw_general_manager" model="res.groups">
        <field name="name">Ерөнхий менежер</field>
        <field name="category_id" ref="base.module_category_project_management"/>
    </record>

    <record id="group_mpw_admin" model="res.groups">
        <field name="name">Худалдан авалтын админ</field>
        <field name="category_id" ref="base.module_category_project_management"/>
        <field name="implied_ids" eval="[(6, 0, [
            ref('municipal_procurement_workflow.group_mpw_requester'),
            ref('municipal_procurement_workflow.group_mpw_storekeeper'),
            ref('municipal_procurement_workflow.group_mpw_finance'),
            ref('municipal_procurement_workflow.group_mpw_office_clerk'),
            ref('municipal_procurement_workflow.group_mpw_contract_officer'),
            ref('municipal_procurement_workflow.group_mpw_director'),
            ref('municipal_procurement_workflow.group_mpw_general_manager')
        ])]"/>
    </record>
</odoo>
