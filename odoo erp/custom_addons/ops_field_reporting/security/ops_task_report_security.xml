<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_ops_task_field_report_system_admin" model="ir.rule">
        <field name="name">OPS field report: system admin all</field>
        <field name="model_id" ref="model_ops_task_report"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('ops_role_security.group_ops_system_admin'))]"/>
    </record>

    <record id="rule_ops_task_field_report_general_manager" model="ir.rule">
        <field name="name">OPS field report: general manager all</field>
        <field name="model_id" ref="model_ops_task_report"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_unlink" eval="False"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('ops_role_security.group_ops_general_manager'))]"/>
    </record>

    <record id="rule_ops_task_field_report_project_leader" model="ir.rule">
        <field name="name">OPS field report: project leader assigned project reports</field>
        <field name="model_id" ref="model_ops_task_report"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_unlink" eval="False"/>
        <field name="domain_force">[('task_id.project_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('ops_role_security.group_ops_project_leader'))]"/>
    </record>

    <record id="rule_ops_task_field_report_team_leader" model="ir.rule">
        <field name="name">OPS field report: team leader assigned task reports</field>
        <field name="model_id" ref="model_ops_task_report"/>
        <field name="domain_force">[('task_id.user_ids', 'in', user.id)]</field>
        <field name="groups" eval="[(4, ref('ops_role_security.group_ops_team_leader'))]"/>
    </record>
</odoo>
