<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_employee_clearance_search" model="ir.ui.view">
        <field name="name">hr.employee.clearance.search</field>
        <field name="model">hr.employee.clearance</field>
        <field name="arch" type="xml">
            <search string="Тойрох хуудас">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="employee_department_id"/>
                <field name="clearance_type"/>
                <field name="request_date"/>
                <filter string="Ноорог" name="filter_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Явцад" name="filter_in_progress" domain="[('state', '=', 'in_progress')]"/>
                <filter string="Дууссан" name="filter_done" domain="[('state', '=', 'done')]"/>
                <filter string="Цуцлагдсан" name="filter_cancelled" domain="[('state', '=', 'cancelled')]"/>
                <separator/>
                <filter string="Өөрийн хүсэлтээр гарах" name="filter_resignation" domain="[('clearance_type', '=', 'resignation')]"/>
                <filter string="Ажлаас чөлөөлөх" name="filter_termination" domain="[('clearance_type', '=', 'termination')]"/>
                <filter string="Шилжилт хөдөлгөөн" name="filter_transfer" domain="[('clearance_type', '=', 'transfer')]"/>
                <separator/>
                <filter string="Огноо" name="filter_request_date" date="request_date"/>
                <group>
                    <filter string="Төлөв" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Төрөл" name="group_type" context="{'group_by': 'clearance_type'}"/>
                    <filter string="Хэлтэс" name="group_department" context="{'group_by': 'employee_department_id'}"/>
                    <filter string="Ажилтан" name="group_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Огноо" name="group_request_date" context="{'group_by': 'request_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_hr_employee_clearance_list" model="ir.ui.view">
        <field name="name">hr.employee.clearance.list</field>
        <field name="model">hr.employee.clearance</field>
        <field name="arch" type="xml">
            <list string="Тойрох хуудасны бүртгэл" default_order="request_date desc"
                  decoration-info="state == 'in_progress'"
                  decoration-success="state == 'done'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="employee_department_id"/>
                <field name="employee_job_id"/>
                <field name="clearance_type"/>
                <field name="request_date"/>
                <field name="effective_date"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_hr_employee_clearance_form" model="ir.ui.view">
        <field name="name">hr.employee.clearance.form</field>
        <field name="model">hr.employee.clearance</field>
        <field name="arch" type="xml">
            <form string="Тойрох хуудас">
                <header>
                    <button name="button_start_progress"
                            string="Явцад оруулах"
                            type="object"
                            class="btn btn-primary"
                            invisible="state != 'draft'"
                            groups="hr_clearance_mn.group_hr_clearance_user,hr_clearance_mn.group_hr_clearance_manager,hr.group_hr_manager,base.group_system"/>
                    <button name="button_done"
                            string="Дуусгах"
                            type="object"
                            class="btn btn-primary"
                            invisible="state != 'in_progress'"
                            groups="hr_clearance_mn.group_hr_clearance_user,hr_clearance_mn.group_hr_clearance_manager,hr.group_hr_manager,base.group_system"/>
                    <button name="button_cancel"
                            string="Цуцлах"
                            type="object"
                            class="btn btn-secondary"
                            invisible="state not in ('draft', 'in_progress')"
                            groups="hr_clearance_mn.group_hr_clearance_user,hr_clearance_mn.group_hr_clearance_manager,hr.group_hr_manager,base.group_system"/>
                    <button name="button_reset_to_draft"
                            string="Ноорог болгох"
                            type="object"
                            class="btn btn-secondary"
                            invisible="state != 'cancelled'"
                            groups="hr_clearance_mn.group_hr_clearance_manager,hr.group_hr_manager,base.group_system"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,in_progress,done,cancelled"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Цуцлагдсан" bg_color="text-bg-danger" invisible="state != 'cancelled'"/>
                    <notebook>
                        <page string="Ерөнхий мэдээлэл">
                            <group>
                                <group>
                                    <field name="name"/>
                                    <field name="employee_id" readonly="state in ('done', 'cancelled')"/>
                                    <field name="employee_department_id" readonly="1"/>
                                    <field name="employee_job_id" readonly="1"/>
                                    <field name="clearance_type" readonly="state in ('done', 'cancelled')"/>
                                </group>
                                <group>
                                    <field name="request_date" readonly="state in ('done', 'cancelled')"/>
                                    <field name="effective_date" readonly="state in ('done', 'cancelled')"/>
                                    <field name="created_by_id"/>
                                    <field name="hr_responsible_id" readonly="state == 'done'"/>
                                    <field name="company_id" groups="base.group_multi_company"/>
                                </group>
                            </group>
                            <group>
                                <field name="reason" readonly="state == 'done'"/>
                            </group>
                        </page>
                        <page string="Шалгалтууд">
                            <group string="Хүний нөөц">
                                <group>
                                    <field name="hr_check_done" readonly="state == 'done'"/>
                                    <field name="hr_check_date" readonly="state == 'done'"/>
                                </group>
                                <group>
                                    <field name="hr_note" readonly="state == 'done'"/>
                                </group>
                            </group>
                            <group string="Санхүү">
                                <group>
                                    <field name="finance_check_done" readonly="state == 'done'"/>
                                    <field name="finance_check_date" readonly="state == 'done'"/>
                                </group>
                                <group>
                                    <field name="finance_note" readonly="state == 'done'"/>
                                </group>
                            </group>
                            <group string="МТ / Хандалт">
                                <group>
                                    <field name="it_check_done" readonly="state == 'done'"/>
                                    <field name="it_check_date" readonly="state == 'done'"/>
                                </group>
                                <group>
                                    <field name="it_note" readonly="state == 'done'"/>
                                </group>
                            </group>
                            <group string="Эд хөрөнгө">
                                <group>
                                    <field name="asset_check_done" readonly="state == 'done'"/>
                                    <field name="asset_check_date" readonly="state == 'done'"/>
                                </group>
                                <group>
                                    <field name="asset_note" readonly="state == 'done'"/>
                                </group>
                            </group>
                            <group string="Удирдлага">
                                <group>
                                    <field name="manager_check_done" readonly="state == 'done'"/>
                                    <field name="manager_check_date" readonly="state == 'done'"/>
                                </group>
                                <group>
                                    <field name="manager_note" readonly="state == 'done'"/>
                                </group>
                            </group>
                            <group string="Эцсийн хүний нөөцийн баталгаажуулалт">
                                <group>
                                    <field name="final_hr_done" readonly="state == 'done'"/>
                                    <field name="final_hr_date" readonly="state == 'done'"/>
                                </group>
                                <group>
                                    <field name="final_hr_note" readonly="state == 'done'"/>
                                </group>
                            </group>
                        </page>
                        <page string="Хавсралт / Тэмдэглэл">
                            <group>
                                <field name="attachment_ids" widget="many2many_binary" readonly="state == 'done'"/>
                                <field name="note" readonly="state == 'done'"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter reload_on_follower="True"/>
            </form>
        </field>
    </record>

    <record id="action_hr_employee_clearance" model="ir.actions.act_window">
        <field name="name">Тойрох хуудасны бүртгэл</field>
        <field name="res_model">hr.employee.clearance</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_hr_employee_clearance_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Шинэ тойрох хуудас үүсгэнэ үү.</p>
        </field>
    </record>
</odoo>
