<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_municipal_role_ui" model="ir.ui.view">
        <field name="name">res.users.form.municipal.role.ui</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="ops_people_registry.view_users_form_ops_registry"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='access_rights']//field[@name='ops_department_id']" position="after">
                <field name="municipal_role_code"/>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button
                    type="object"
                    name="action_open_municipal_dashboard"
                    class="oe_stat_button"
                    icon="fa-dashboard"
                    groups="municipal_role_ui.group_role_system_admin,base.group_system"
                >
                    <div class="o_stat_info">
                        <span class="o_stat_text">Ажлын орон зай</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
