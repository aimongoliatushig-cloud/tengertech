        <field name="model_id" ref="model_municipal_role_dashboard"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(6, 0, [ref('municipal_role_ui.group_role_director'), ref('municipal_role_ui.group_role_general_manager'), ref('municipal_role_ui.group_role_department_head'), ref('municipal_role_ui.group_role_project_leader'), ref('municipal_role_ui.group_role_senior_master'), ref('municipal_role_ui.group_role_master'), ref('municipal_role_ui.group_role_employee'), ref('municipal_role_ui.group_role_hr'), ref('municipal_role_ui.group_role_accountant'), ref('municipal_role_ui.group_role_finance_officer'), ref('municipal_role_ui.group_role_storekeeper'), ref('municipal_role_ui.group_role_office_clerk'), ref('municipal_role_ui.group_role_contract_officer'), ref('municipal_role_ui.group_role_garage_mechanic'), ref('municipal_role_ui.group_role_driver'), ref('municipal_role_ui.group_role_loader'), ref('municipal_role_ui.group_role_inspector')])]"/>
    </record>

