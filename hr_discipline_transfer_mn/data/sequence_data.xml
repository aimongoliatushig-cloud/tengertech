        <record id="seq_hr_disciplinary_action" model="ir.sequence">
            <field name="name">Сахилгын бүртгэлийн дугаар</field>
            <field name="code">hr.disciplinary.action</field>
            <field name="prefix">DISC/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_hr_employee_transfer" model="ir.sequence">
            <field name="name">Шилжилт хөдөлгөөний дугаар</field>
            <field name="code">hr.employee.transfer</field>
            <field name="prefix">MOVE/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
