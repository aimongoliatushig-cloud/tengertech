<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="res_groups_privilege_hr_clearance" model="res.groups.privilege">
            <field name="name">HR тойрох хуудас</field>
            <field name="sequence">45</field>
            <field name="category_id" ref="base.module_category_human_resources"/>
        </record>

        <record id="group_hr_clearance_user" model="res.groups">
            <field name="name">Тойрох хуудасны ажилтан</field>
            <field name="privilege_id" ref="res_groups_privilege_hr_clearance"/>
            <field name="implied_ids" eval="[(4, ref('hr.group_hr_user'))]"/>
        </record>

        <record id="group_hr_clearance_manager" model="res.groups">
            <field name="name">Тойрох хуудасны менежер</field>
            <field name="privilege_id" ref="res_groups_privilege_hr_clearance"/>
            <field name="implied_ids" eval="[(4, ref('group_hr_clearance_user'))]"/>
        </record>

        <record id="rule_hr_employee_clearance_user_company" model="ir.rule">
            <field name="name">Тойрох хуудас: компанийн хүрээ</field>
            <field name="model_id" ref="model_hr_employee_clearance"/>
            <field name="groups" eval="[(4, ref('group_hr_clearance_user'))]"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_hr_employee_clearance_manager_all" model="ir.rule">
            <field name="name">Тойрох хуудас: менежер бүхийг харна</field>
            <field name="model_id" ref="model_hr_employee_clearance"/>
            <field name="groups" eval="[(4, ref('group_hr_clearance_manager')), (4, ref('hr.group_hr_manager')), (4, ref('base.group_system'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>
    </data>
</odoo>
